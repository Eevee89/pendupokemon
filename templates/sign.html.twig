<div id="signModal" class="modal" tabindex="-1" role="dialog">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">{{ 'modal.title'|trans({}, 'sign')}}</h5>
            </div>
            <div class="modal-body">
                <ul class="nav nav-tabs" id="myTab" role="tablist">
                    <li class="nav-item" role="presentation">
                        <button class="nav-link active" id="signup-tab" 
                                data-bs-toggle="tab" data-bs-target="#signup" 
                                type="button" role="tab" aria-controls="signup" 
                                aria-selected="true">
                            {{ 'modal.tabs.signup'|trans({}, 'sign')}}
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button 
                            class="nav-link" id="signin-tab" 
                            data-bs-toggle="tab" data-bs-target="#signin" 
                            type="button" role="tab" aria-controls="signin" 
                            aria-selected="false">
                            {{ 'modal.tabs.signin'|trans({}, 'sign')}}
                        </button>
                    </li>
                </ul>
                <div class="tab-content" id="myTabContent">
                    <div class="tab-pane fade show active" id="signup" role="tabpanel" aria-labelledby="signup-tab">
                        <form id="signUpForm" class="row g-3 needs-validation mt-1" novalidate>
                            <div class="col-md-12">
                                <label for="newUsername" class="form-label">{{ 'modal.username'|trans({}, 'sign')}}</label>
                                <input type="text" class="form-control" id="newUsername" value="" name="newUsername" required maxlength="32">
                                <div class="valid-feedback">
                                    {{ 'modal.formControlOK'|trans({}, 'sign')}}
                                </div>
                                <div class="invalid-feedback">
                                    {{ 'modal.formControlKO'|trans({}, 'sign')}}
                                </div>
                            </div>
                            <div class="col-md-6">
                                <label for="newPassword" class="form-label">{{ 'modal.password'|trans({}, 'sign')}}</label>
                                <div class="input-group mb-3">
                                    <input class="form-control password" id="newPassword" class="block mt-1 w-full" type="password" name="newPassword" value="" required maxlength="32"/>
                                    <span class="input-group-text togglePassword" data-for="newPassword">
                                        <i class="fa fa-eye" data-for="newPassword"></i>
                                    </span>
                                    <div class="valid-feedback">
                                        {{ 'modal.formControlOK'|trans({}, 'sign')}}
                                    </div>
                                    <div class="invalid-feedback">
                                        {{ 'modal.formControlKO'|trans({}, 'sign')}}
                                    </div>
                                </div>
                            </div>
                            <div id="confirmPasswordDiv" class="col-md-6">
                                <label for="confirmPassword" class="form-label">{{ 'modal.passwordConf'|trans({}, 'sign')}}</label>
                                <div class="input-group mb-3">
                                    <input class="form-control password" id="confirmPassword" class="block mt-1 w-full" type="password" value="" required maxlength="32"/>
                                    <span class="input-group-text togglePassword" data-for="confirmPassword">
                                        <i class="fa fa-eye" data-for="confirmPassword"></i>
                                    </span>
                                    <div id="password-does-not-match-text" class="text-danger" hidden>
                                        {{ 'modal.passwordKO'|trans({}, 'sign')}}
                                    </div>
                                    <div class="valid-feedback">
                                        {{ 'modal.formControlOK'|trans({}, 'sign')}}
                                    </div>
                                    <div class="invalid-feedback">
                                        {{ 'modal.formControlKO'|trans({}, 'sign')}}
                                    </div>
                                </div>
                            </div>
                            <div class="col-12 d-flex flex-row-reverse">
                                <button id="signUpSubmit" class="btn btn-primary" type="submit">{{ 'modal.submit'|trans({}, 'sign')}}</button>
                            </div>
                        </form>
                    </div>
                    <div class="tab-pane fade" id="signin" role="tabpanel" aria-labelledby="signin-tab">
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<script>
const signupurl = "{{ path('app_register') }}";

let successSwal = {
    "title": "{{ 'swal.success.title'|trans({}, 'sign')}}",
    "text": "{{ 'swal.success.text'|trans({}, 'sign')}}",
    "icon": "success",
    "button": "OK"
};

const errorTexts = {
    "missingParams": "{{ 'swal.error.missingParams'|trans({}, 'sign')}}",
    "usernameTaken": "{{ 'swal.error.usernameTaken'|trans({}, 'sign')}}".replace("&#039;", "'"),
    "servorError": "{{ 'swal.error.servorError'|trans({}, 'sign')}}"
}

let errorSwal = {
    "title": "{{ 'swal.error.title'|trans({}, 'sign')|raw}}",
    "text": "",
    "icon": "error",
    "button": "OK"
};
</script>
<script src="scripts/sign.js"></script>